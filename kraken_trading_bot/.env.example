# Kraken API credentials
KRAKEN_API_KEY=your_api_key_here
KRAKEN_SECRET_KEY=your_secret_key_here

# Trading pairs to monitor and trade
TRADING_PAIRS=["XBT/USD", "ETH/USD", "ADA/USD", "DOT/USD", "LINK/USD"]

# Risk management settings
MAX_POSITION_SIZE=0.1
MAX_DAILY_LOSS=0.05
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04

# Technical analysis parameters
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70

MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

BOLLINGER_PERIOD=20
BOLLINGER_STD=2.0

# Timeframes for analysis
TIMEFRAMES=["1m", "5m", "15m", "1h", "4h", "1d"]

# Database configuration
DATABASE_URL=postgresql://user:password@localhost/kraken_bot

# Redis configuration
REDIS_URL=redis://localhost:6379

# Logging configuration
LOG_LEVEL=INFO
LOG_FILE=logs/trading_bot.log

# Web interface configuration
WEB_PORT=8000
WEB_HOST=0.0.0.0

# Performance tracking
PERFORMANCE_METRICS=["sharpe_ratio", "max_drawdown", "win_rate", "profit_factor"]

# Advanced features
ENABLE_ML=true
ENABLE_SENTIMENT=true
ENABLE_NEWS=true
ENABLE_ARBITRAGE=true

# Machine learning parameters
ML_MODEL_PATH=models/
ML_RETRAIN_INTERVAL=24

# Sentiment analysis sources
SENTIMENT_SOURCES=["twitter", "reddit", "news"]

# Arbitrage settings
ARBITRAGE_THRESHOLD=0.005
ARBITRAGE_EXCHANGES=["binance", "coinbase", "kraken"]