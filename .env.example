# Kraken API Configuration
# Get your API keys from: https://www.kraken.com/u/settings/api
KRAKEN_API_KEY=your_api_key_here
KRAKEN_SECRET_KEY=your_secret_key_here
KRAKEN_SANDBOX=true  # Set to false for live trading

# Database Configuration
DATABASE_URL=postgresql://postgres:password@postgres:5432/kraken_bot
REDIS_URL=redis://redis:6379

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/trading_bot.log

# Trading Parameters
TRADING_PAIRS=["XBT/USD","ETH/USD","ADA/USD"]
BASE_CURRENCY=USD
MAX_POSITION_SIZE=0.1  # 10% of portfolio per trade
MAX_DAILY_LOSS=0.02    # 2% daily loss limit
MAX_DAILY_TRADES=50    # Maximum trades per day
MIN_TRADE_AMOUNT=10.0  # Minimum trade amount in USD

# Risk Management
STOP_LOSS_PERCENTAGE=0.02      # 2% stop loss
TAKE_PROFIT_PERCENTAGE=0.04    # 4% take profit
TRAILING_STOP=true             # Enable trailing stops
TRAILING_STOP_PERCENTAGE=0.01  # 1% trailing stop

# Technical Analysis Parameters
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BOLLINGER_PERIOD=20
BOLLINGER_STD=2.0

# Web Interface
WEB_PORT=8080
WEB_HOST=0.0.0.0

# Monitoring
PROMETHEUS_PORT=8000
GRAFANA_URL=http://localhost:3000

# External APIs (Optional - for enhanced features)
ALPHA_VANTAGE_API_KEY=        # For additional market data
NEWS_API_KEY=                 # For sentiment analysis
TELEGRAM_BOT_TOKEN=           # For notifications
TELEGRAM_CHAT_ID=             # Your Telegram chat ID

# Email Notifications (Optional)
EMAIL_SMTP_SERVER=
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Machine Learning (Optional)
MODEL_PATH=models/
RETRAIN_INTERVAL_HOURS=24