# Kraken Trading Bot Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# KRAKEN API CONFIGURATION
# =============================================================================

# Your Kraken API credentials (get from https://www.kraken.com/u/settings/api)
KRAKEN_API_KEY=your_api_key_here
KRAKEN_SECRET_KEY=your_secret_key_here

# Use sandbox for testing (true) or live trading (false)
KRAKEN_SANDBOX=true

# =============================================================================
# TRADING PARAMETERS
# =============================================================================

# Trading pairs to monitor (comma-separated)
TRADING_PAIRS=["XBT/USD", "ETH/USD", "ADA/USD"]

# Base currency for calculations
BASE_CURRENCY=USD

# Maximum position size as percentage of portfolio (0.1 = 10%)
MAX_POSITION_SIZE=0.1

# Maximum number of trades per day
MAX_DAILY_TRADES=50

# Minimum trade amount in base currency
MIN_TRADE_AMOUNT=10.0

# =============================================================================
# RISK MANAGEMENT
# =============================================================================

# Stop loss percentage (0.02 = 2%)
STOP_LOSS_PERCENTAGE=0.02

# Take profit percentage (0.04 = 4%)
TAKE_PROFIT_PERCENTAGE=0.04

# Maximum drawdown allowed (0.15 = 15%)
MAX_DRAWDOWN=0.15

# Daily loss limit (0.05 = 5%)
DAILY_LOSS_LIMIT=0.05

# =============================================================================
# TECHNICAL ANALYSIS
# =============================================================================

# Moving average periods
SHORT_MA_PERIOD=10
LONG_MA_PERIOD=50

# RSI settings
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# Bollinger Bands settings
BOLLINGER_PERIOD=20
BOLLINGER_STD=2.0

# =============================================================================
# MACHINE LEARNING
# =============================================================================

# Path to store ML models
ML_MODEL_PATH=models/

# Feature window for ML models
FEATURE_WINDOW=100

# Prediction confidence threshold
PREDICTION_THRESHOLD=0.6

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database URL (SQLite by default)
DATABASE_URL=sqlite:///trading_bot.db

# Redis URL for caching
REDIS_URL=redis://localhost:6379

# =============================================================================
# LOGGING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/trading_bot.log

# =============================================================================
# MONITORING
# =============================================================================

# Metrics server port
METRICS_PORT=8000

# Dashboard port
DASHBOARD_PORT=8050

# =============================================================================
# NEWS AND SENTIMENT
# =============================================================================

# News API key (get from https://newsapi.org/)
NEWS_API_KEY=your_news_api_key_here

# Twitter API credentials (get from https://developer.twitter.com/)
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# =============================================================================
# BACKTESTING
# =============================================================================

# Backtest date range
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2024-01-01

# Initial balance for backtesting
BACKTEST_INITIAL_BALANCE=10000.0

# =============================================================================
# ADVANCED FEATURES
# =============================================================================

# Enable grid trading
ENABLE_GRID_TRADING=false

# Grid trading levels
GRID_LEVELS=10

# Grid spacing percentage
GRID_SPACING=0.02

# Enable dollar cost averaging
ENABLE_DCA=false

# DCA interval in hours
DCA_INTERVAL=24

# DCA amount
DCA_AMOUNT=100.0

# Enable arbitrage detection
ENABLE_ARBITRAGE=false

# Arbitrage threshold (0.005 = 0.5%)
ARBITRAGE_THRESHOLD=0.005

# =============================================================================
# NOTIFICATIONS
# =============================================================================

# Email notifications (optional)
EMAIL_ENABLED=false
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENTS=["your_email@gmail.com"]

# Telegram notifications (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Discord notifications (optional)
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=your_webhook_url_here

# =============================================================================
# SECURITY
# =============================================================================

# Encryption key for sensitive data (generate a random 32-byte key)
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# API rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# PERFORMANCE OPTIMIZATION
# =============================================================================

# Data update interval in seconds
UPDATE_INTERVAL=60

# Maximum concurrent API requests
MAX_CONCURRENT_REQUESTS=10

# Cache timeout in seconds
CACHE_TIMEOUT=300

# =============================================================================
# DEVELOPMENT
# =============================================================================

# Enable debug mode
DEBUG=false

# Enable verbose logging
VERBOSE=false

# Enable profiling
PROFILING=false

# Test mode (disables real trading)
TEST_MODE=false